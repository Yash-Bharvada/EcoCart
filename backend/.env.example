# ============================================================
# EcoCart Backend — Environment Variables
# Copy this file to .env and fill in all values before running
# ============================================================

# ----------------------------
# Application
# ----------------------------
ENVIRONMENT=development
API_VERSION=1.0.0
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
DEBUG=True
LOG_LEVEL=INFO

# ----------------------------
# Database — MongoDB
# ----------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=ecocart

# For MongoDB Atlas (cloud):
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# ----------------------------
# Database — Redis
# ----------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ----------------------------
# AI — Google Gemini
# ----------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_FREE=gemini-1.5-flash-latest
GEMINI_MODEL_PREMIUM=gemini-1.5-pro-latest

# ----------------------------
# Authentication (Google OAuth)
# ----------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ----------------------------
# Cloud Storage — AWS S3
# ----------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=ecocart-receipts
AWS_REGION=us-east-1
S3_RECEIPT_PREFIX=receipts/
S3_THUMBNAIL_PREFIX=thumbnails/

# ----------------------------
# Email — SMTP
# ----------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=EcoCart

# ----------------------------
# Frontend / CORS
# ----------------------------
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ----------------------------
# Security / Token Expiry
# ----------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1
BCRYPT_ROUNDS=12

# ----------------------------
# Rate Limiting
# ----------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ANALYZE_FREE=10
RATE_LIMIT_ANALYZE_PREMIUM=60
MONTHLY_ANALYSIS_LIMIT_FREE=5

# ----------------------------
# Carbon Offset Pricing
# ----------------------------
CARBON_OFFSET_PRICE_PER_TON=15.00
ECOCART_SERVICE_FEE_PERCENT=7.5

# ----------------------------
# Monitoring (optional)
# ----------------------------
SENTRY_DSN=
